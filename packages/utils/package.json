{
  "name": "@streamr/utils",
  "version": "103.2.0-rc.0",
  "description": "A collection of shared common utilities",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/streamr-dev/network.git",
    "directory": "packages/utils"
  },
  "types": "./dist/node/src/exports.d.ts",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/browser/src/exports.d.ts",
        "import": "./dist/browser/src/exports.js",
        "require": "./dist/browser/src/exports.cjs"
      },
      "types": "./dist/node/src/exports.d.ts",
      "import": "./dist/node/src/exports.js",
      "require": "./dist/node/src/exports.cjs"
    }
  },
  "files": [
    "dist/node/src/exports.*",
    "dist/browser/src/exports.*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": " tsc -b",
    "postbuild": "rollup -c dist/rollup.config.mjs",
    "check": "tsc -p ./tsconfig.jest.json && tsc --noEmit -p ./tsconfig.node.json",
    "clean": "jest --clearCache || true; rm -rf dist *.tsbuildinfo node_modules/.cache || true",
    "eslint": "eslint --cache --cache-location=node_modules/.cache/.eslintcache/ '*/**/*.{js,ts}'",
    "test": "jest",
    "test-browser": "karma start karma.config.ts"
  },
  "author": "Streamr Network AG <contact@streamr.network>",
  "license": "Apache-2.0",
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@noble/post-quantum": "^0.4.1",
    "buffer": "^6.0.3",
    "buffer-shim": "^1.0.1",
    "eventemitter3": "^5.0.0",
    "lodash": "^4.17.21",
    "md5": "^2.3.0",
    "path-browserify": "^1.0.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "readable-stream": "^4.7.0",
    "secp256k1": "^5.0.1",
    "sha3": "^2.1.4"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@streamr/browser-test-runner": "^0.0.1",
    "@types/lodash": "^4.17.21",
    "@types/md5": "^2.3.6",
    "@types/secp256k1": "^4.0.7",
    "rollup": "^4.53.3",
    "rollup-plugin-dts": "^6.3.0"
  }
}
